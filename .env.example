# OpenAI-compatible LLM settings
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Qdrant vector database
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_RAG=medical_dense
QDRANT_COLLECTION_MEM0=medical_mem0

# RAG tuning
EMBED_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
BM25_TOP_K=50
DENSE_TOP_K=20
RERANK_TOP_K=5
COMPRESS_TOKEN_THRESHOLD=1500

# Agent
SUMMARIZE_EVERY_N_TURNS=6

# Eval
RAGAS_TESTSET_PATH=data/eval/testset.json
RAGAS_BASELINE_PATH=data/eval/baseline_results.json
